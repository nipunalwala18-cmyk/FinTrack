datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Role {
  USER
  ADMIN
}

model User {
  id                  String        @id @default(cuid())
  fullName            String
  email               String        @unique
  password            String?
  provider            AuthProvider  @default(LOCAL)
  providerId          String?
  profileImage        String?
  emailVerified       Boolean       @default(false)
  role                Role          @default(USER)
  hashedRefreshToken  String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  accounts            Account[]
  transactions        Transaction[]
  categories          Category[]
  budgets             Budget[]
  goals               Goal[]
  aiConversations     AiConversation[]
  aiInsights          AiInsight[]
  aiRecommendations   AiRecommendation[]
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  INVESTMENT
  E_WALLET
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Account {
  id                 String        @id @default(cuid())
  name               String
  balance            Float
  currency           String        @default("INR")
  type               AccountType
  color              String?
  icon               String?
  isArchived         Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[] @relation("FromAccount")
  toTransactions     Transaction[] @relation("ToAccount")

  // Extended fields for adaptive account types
  accountNumber      String?
  branch             String?

  creditLimit        Float?
  outstandingBalance Float?
  billingDay         Int?
  paymentDueDay      Int?

  provider           String?

  interestRate       Float?
  investmentDuration Int?

  notes              String?

  includeInNetWorth  Boolean       @default(true)
  displayOrder       Int?

  @@index([userId])
}

model Category {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         TransactionType
  color        String?
  icon         String?
  parentId     String?
  parent       Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Category[]      @relation("CategoryHierarchy")
  sortOrder    Int             @default(0)
  isDefault    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?       // Soft delete

  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@index([parentId])
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  description String?
  notes       String?
  date        DateTime
  type        TransactionType
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account         @relation("FromAccount", fields: [accountId], references: [id], onDelete: Cascade)
  toAccountId String?
  toAccount   Account?        @relation("ToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  goalId           String?
  goal             Goal?             @relation(fields: [goalId], references: [id], onDelete: SetNull)
  contributionType ContributionType?

  @@index([userId])
  @@index([accountId])
  @@index([toAccountId])
  @@index([categoryId])
  @@index([goalId])
  @@index([date])
  @@index([type])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String
  password  String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  categoryId  String

  period      BudgetPeriod
  startDate   DateTime
  endDate     DateTime

  amount      Float

  alertAt     Int?      // percentage (80,90,100)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([categoryId])
}

enum GoalType {
  SAVINGS
  EXPENSE_LIMIT
  INCOME_TARGET
}

enum GoalPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
  ARCHIVED
}

model Goal {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  goalType      GoalType?
  period        GoalPeriod?
  targetAmount  Float
  currentAmount Float         @default(0)
  startDate     DateTime?
  endDate       DateTime?
  targetDate    DateTime?
  status        GoalStatus    @default(ACTIVE)
  color         String?
  icon          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]

  @@index([userId])
}

enum ContributionType {
  DEPOSIT
  WITHDRAWAL
}

model AiConversation {
  id        String               @id @default(uuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  messages  AiMessage[]
  state     AiConversationState?

  @@index([userId])
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolExecuted   String?
  toolSuccess    Boolean?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

model AiConversationState {
  id                  String         @id @default(uuid())
  conversationId      String         @unique
  conversation        AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  pendingIntent       String?
  temporaryParameters Json?
  lastTool            String?
  expiresAt           DateTime?
  updatedAt           DateTime       @updatedAt
}

model AiInsight {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String
  priority    Int      @default(1)
  createdAt   DateTime @default(now())
  dismissed   Boolean  @default(false)

  @@index([userId])
}

model AiRecommendation {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       String
  recommendation String
  confidence     Float
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())

  @@index([userId])
}


